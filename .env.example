# ─────────────────────────────────────────────────────────────────────────────
# Beeceptor Playwright Automation – Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored for security.
# ─────────────────────────────────────────────────────────────────────────────

# Your Beeceptor account credentials
BEECEPTOR_EMAIL=your@email.com
BEECEPTOR_PASSWORD=yourpassword

# The Beeceptor endpoint name to use for tests.
# This endpoint will be created if it doesn't exist, or reused if it does.
# The full URL will be: https://<BEECEPTOR_ENDPOINT>.free.beeceptor.com
BEECEPTOR_ENDPOINT=pw-callout-test
